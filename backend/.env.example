# ==========================================
# CONFIGURACIÓN GENERAL
# ==========================================
PORT=3001
NODE_ENV=development

# ==========================================
# POSTGRES - BASE DE DATOS COMPARTIDA
# ==========================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=facturacion_db

# ==========================================
# JWT - MÓDULO DE SEGURIDAD (Django)
# El secreto debe ser el mismo que usa el módulo de Seguridad
# para firmar los tokens JWT de los usuarios.
# ==========================================
JWT_SECRET=clave_secreta_compartida_entre_modulos
JWT_ALGORITHM=HS256
