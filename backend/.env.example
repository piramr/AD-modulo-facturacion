# ==========================================
# CONFIGURACIÓN GENERAL
# ==========================================
PORT=3003
NODE_ENV=development

# ==========================================
# POSTGRES - BASE DE DATOS COMPARTIDA
# ==========================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=facturacion_db

# ==========================================
# JWT - MÓDULO DE SEGURIDAD (Django)
# ==========================================
JWT_SECRET=clave_secreta_compartida_entre_modulos
JWT_ALGORITHM=HS256

# ==========================================
# API-KEYS
# ==========================================
API_KEY_FACTURACION=cambia_esto_por_una_key_segura
API_KEY_AUDITORIA=pendiente_confirmar_con_equipo_seguridad

# ==========================================
# INVENTARIO — URL REAL CONFIRMADA
# La API ya está desplegada en Render y funcionando.
# Para desarrollo local puedes usar la URL de producción directamente.
# ==========================================
MODULO_INVENTARIO_REST_URL=https://api-inventario-v1gh.onrender.com/api

# ==========================================
# OTROS MÓDULOS (pendientes de confirmar)
# ==========================================
MODULO_SEGURIDAD_GRAPHQL_URL=http://localhost:3000/graphql
MODULO_SEGURIDAD_GRPC_URL=localhost:50051
MODULO_CXC_REST_URL=http://localhost:3004/api
